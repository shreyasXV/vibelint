{
  "name": "vibelint",
  "version": "0.3.0",
  "description": "AI Code Audit — catches bugs your AI coding tool introduces",
  "main": "dist/index.js",
  "bin": {
    "vibelint": "dist-cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:action": "ncc build src/index.ts -o dist",
    "build:cli": "ncc build src/cli.ts -o dist-cli",
    "build:all": "npm run build:action && npm run build:cli",
    "test": "jest --verbose",
    "lint": "tsc --noEmit",
    "package": "npm run build:all",
    "prepublishOnly": "npm run build:all"
  },
  "files": [
    "dist-cli/",
    "dist/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "github-action",
    "ai",
    "code-quality",
    "lint",
    "vibe-coding",
    "cli",
    "code-review",
    "ai-critic",
    "cursor",
    "copilot",
    "claude-code"
  ],
  "author": "Shreyas Shubham <shreyasshubham27@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shreyasXV/vibelint"
  },
  "homepage": "https://github.com/shreyasXV/vibelint",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
